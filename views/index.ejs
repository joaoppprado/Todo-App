<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Todo App</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="page-body">
  <main class="todo-app">

    <header class="todo-app__header">
      <h1 class="todo-title">To-do App</h1>

      <form action="/tasks" method="POST" class="todo-form">
        <input type="text" name="title" class="todo-form__input todo-form__input--title" placeholder="Title" required>
        <input type="text" name="description" class="todo-form__input todo-form__input--description" placeholder="Task description">
        <button type="submit" class="todo-form__submit-btn">Add</button>
      </form>

      <nav class="todo-filters">
        <a href="" class="todo-filters__btn todo-filters__btn--active">All</a>
        <a href="" class="todo-filters__btn">Completed</a>
        <a href="" class="todo-filters__btn">In Progress</a>
        <a href="" class="todo-filters__btn">Pending</a>
      </nav>
    </header>

    <section class="todo-app__content">

      <% if (typeof tasks !== 'undefined' && tasks.length > 0) { %>
      <ul class="task-list">
        <% tasks.forEach(task => { %>
        <% let statusClass = ''; 
                       let statusIcon = '';
                       if (task.status === 'pending') {
                         statusClass = 'task--pending';
                         
                       } else if (task.status === 'in progress') {
                         statusClass = 'task--in-progress';
                         
                       } else if (task.status === 'concluded') {
                         statusClass = 'task--completed';
                       }
                    %>
        <li class="task <%= statusClass %>">
          <div class="task__status-indicator">
            <%- statusIcon %>
          </div>

          <div class="task__content">
            <h3 class="task__title <%= task.status === 'concluded' ? 'task__title--completed' : '' %>"><%= task.title %></h3>
            <p class="task__description"><%= task.description %></p>

            <div class="task__meta">
              <span class="task__badge">Created: <%= task.created %></span>
              <span class="task__badge">Modified: <%= task.modified %></span>
              <span class="task__status-text">
                <%= task.status %>
              </span>
            </div>
          </div>
          <div class="task__actions">
            <button class="task__btn" aria-label="Edit" data-action="edit" data-id="<%= task.id %>">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
            </button>
            <button class="task__btn" aria-label="Priority" data-action="priority" data-id="<%= task.id %>">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
            </button>
            <button class="task__btn task__btn--danger" aria-label="Delete" data-action="delete" data-id="<%= task.id %>">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </div>
        </li>
        <% }); %>
      </ul>
      <% } else { %>
      <div class="empty-state">
        <svg class="empty-state__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 2H15C16.1046 2 17 2.89543 17 4V6H7V4C7 2.89543 7.89543 2 9 2Z" fill="transparent" />
          <path d="M7 6H5C3.89543 6 3 6.89543 3 8V20C3 21.1046 3.89543 22 5 22H19C20.1046 22 21 21.1046 21 20V8C21 6.89543 20.1046 6 19 6H17" />
          <path d="M8 12H16" />
          <path d="M8 16H12" />
        </svg>
        <p class="empty-state__title">No tasks to do...</p>
        <p class="empty-state__subtitle">Create tasks and be ready for your day</p>
      </div>
      <% } %>

    </section>

    <footer class="todo-app__footer">
      <div class="todo-stats">
        <div class="todo-stats__item">
          <span class="todo-stats__label todo-stats__label--created">Created tasks:</span>
          <span class="todo-stats__badge"><%= typeof totalTasks !== 'undefined' ? totalTasks : 0 %></span>
        </div>
        <div class="todo-stats__item">
          <span class="todo-stats__label todo-stats__label--completed">Completed:</span>
          <span class="todo-stats__badge"><%= typeof completedTasks !== 'undefined' ? completedTasks : 0 %></span>
        </div>
      </div>
    </footer>

    <script src="/js/taskActions.js"></script>
  </main>
</body>

</html>